# =============================================
# AGENTE DE VENTAS AI — Variables de entorno
# Copia como .env y completa todos los valores
# =============================================

# ── App ──────────────────────────────────────
APP_ENV=development           # development | production
DEBUG=true
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-de-64-chars-minimo

# ── Base de datos ─────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-este-password
POSTGRES_DB=agente_ventas
# En Docker el host es "postgres"; en local es "localhost"
DATABASE_URL=postgresql+asyncpg://postgres:cambia-este-password@postgres:5432/agente_ventas

# ── Redis ────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Anthropic Claude (REQUERIDO) ─────────────
ANTHROPIC_API_KEY=sk-ant-api03-AQUI-TU-KEY

# ── WhatsApp / Twilio ─────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Instagram / Meta Graph API ────────────────
INSTAGRAM_ACCESS_TOKEN=tu-page-access-token
INSTAGRAM_APP_SECRET=tu-app-secret
INSTAGRAM_VERIFY_TOKEN=token-personalizado-para-verificacion

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxx

# ── Resend (emails transaccionales) ───────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@tu-dominio.com
EMAIL_FROM_NAME=Agente de Ventas AI

# ── OpenAI (embeddings — opcional) ────────────


# ── Frontend ──────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Docker build target ───────────────────────
BUILD_TARGET=development      # development | production
