# =============================================
# AGENTE DE VENTAS - Environment Variables
# =============================================

# App
APP_NAME="Agente de Ventas AI"
APP_ENV=development
SECRET_KEY=your-super-secret-key-min-32-chars-change-this
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/agente_ventas

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-api03-...

# WhatsApp Business API (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# OpenAI (para embeddings)


# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
FRONTEND_URL=http://localhost:3000

# WebSocket
WS_URL=ws://localhost:8000
